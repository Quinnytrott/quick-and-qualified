# Q2 site URL helpers
# Use the deployed site URL in Production. Vercel also provides VERCEL_URL automatically.
SITE_URL=https://www.quickandqualified.ca
NEXT_PUBLIC_SITE_URL=https://www.quickandqualified.ca

# Admin viewer signing
# Generate with a password manager or: openssl rand -base64 32
LEAD_VIEWER_SECRET=replace-with-long-random-secret

# Contractor applications list gate
# This token is required for /admin/contractor-applications?token=<token>.
CONTRACTOR_APPLICATIONS_ADMIN_TOKEN=replace-with-long-random-admin-token

# Firebase Admin for Q2 leads, contractor applications, and uploaded photos
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_CLIENT_EMAIL=replace-with-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=replace-with-storage-bucket.appspot.com

# Resend email notifications and webhook status updates
RESEND_API_KEY=replace-with-resend-api-key
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
LEAD_NOTIFICATION_FROM="Q2 Leads <leads@quickandqualified.ca>"

# MeasureAgent bridge for converting homeowner leads into measurement projects
MEASUREAGENT_FIREBASE_PROJECT_ID=roofmeasure-8g2ch
MEASUREAGENT_FIREBASE_CLIENT_EMAIL=replace-with-measureagent-firebase-client-email
MEASUREAGENT_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"
MEASUREAGENT_OWNER_UID=replace-with-measureagent-owner-uid
MEASUREAGENT_COMPANY_ID=replace-with-measureagent-company-id
MEASUREAGENT_SITE_URL=https://measureagent.ca
